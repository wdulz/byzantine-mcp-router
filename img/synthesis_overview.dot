digraph Synthesis {
  graph [fontsize=14, fontname="Calibri", compound=true, ranksep=0.8]
  node [fontname="Calibri", fontsize=12, style="rounded,filled", shape=box]
  edge [fontname="Calibri", fontsize=10]

  subgraph cluster_theory {
    label = "1. Theoretical Limits (Uncomputability)"
    style = "dashed,rounded"
    color = "#e41a1c"
    fontcolor = "#e41a1c"
    Limits [label="Rice, Gödel & Cryptographic Proofs\n(Static safety and asymmetrical wrappers\nare mathematically broken)", fillcolor="#fbb4ae"]
  }

  subgraph cluster_threats {
    label = "2. Adversarial Environment"
    style = "dashed,rounded"
    color = "#ff7f00"
    fontcolor = "#ff7f00"
    Threats [label="BYOMCP Worms & Architectural Sybil Attacks\n(Prompt infections & common-mode failures)", fillcolor="#fdbf6f"]
  }

  subgraph cluster_bmr {
    label = "3. Byzantine MCP Router (Reactive Defense)"
    style = "solid,rounded"
    color = "#377eb8"
    fontcolor = "#377eb8"
    bgcolor = "#f0f8ff"
    
    Topo [label="1:R:N Sandboxed Topology\n(Enforces Topological Authority)", fillcolor="#b3cde3"]
    Hetero [label="Forced Heterogeneity\n(Breaks Sybil correlations)", fillcolor="#b3cde3"]
    SCA [label="Action-Space Consensus (SCA)\n(Computes vector similarity quorum)", fillcolor="#b3cde3"]
    
    {Topo Hetero} -> SCA [style=invis] // Layout structuring
  }

  subgraph cluster_resolution {
    label = "4. Formal Resolution & Accountability"
    style = "solid,rounded"
    color = "#4daf4a"
    fontcolor = "#4daf4a"
    
    EPN [label="Extended Petri Net (EPN)\n(Guarantees human-in-the-loop commit)", fillcolor="#ccebc5"]
    Morpheus [label="Morpheus Quarantine\n(Preserves constructive anomalies)", fillcolor="#ccebc5"]
  }

  Limits -> Topo [ltail=cluster_theory, lhead=cluster_bmr, label=" Necessitates reactive resilience", color="#e41a1c", penwidth=2]
  Threats -> Topo [ltail=cluster_threats, lhead=cluster_bmr, label=" Intercepted by proxy", color="#ff7f00", penwidth=2]
  
  SCA -> EPN [label=" Majority Quorum (|C| >= Q)", color="#4daf4a", penwidth=2]
  SCA -> Morpheus [label=" Semantic Outliers (|C| < Q)", color="#984ea3", penwidth=2, style=dashed]
}